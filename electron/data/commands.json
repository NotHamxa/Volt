    "appId": null,
    "path": "powershell -NoProfile -Command \"(netsh wlan show profiles) | Select-String '\\:(.+)$' | %{ $name=$_.Matches.Groups[1].Value.Trim(); $info=(netsh wlan show profile name=\\\"$name\\\" key=clear); $key=($info | Select-String 'Key Content\\W+\\:(.+)$').Matches.Groups[1].Value.Trim(); [pscustomobject]@{ SSID=$name; Password=$key } } | Format-Table -AutoSize\"",
    "source": "predefined"
